# ============================================
# ORACLE DATABASE CREDENTIALS - TEMPLATE
# Copy this to .env and fill in your actual passwords
# ============================================

# Oracle Cloud Autonomous Database
ORACLE_VERSION=19c
ORACLE_DATABASE=BANKDB

# Admin credentials (ADMIN user - full control)
ADMIN_USERNAME=ADMIN
ADMIN_PASSWORD=your_admin_password_here

# Application schema credentials (BANK_SCHEMA - our application user)
BANK_SCHEMA_USERNAME=BANK_SCHEMA
BANK_SCHEMA_PASSWORD=your_schema_password_here

# Wallet configuration
WALLET_PASSWORD=your_wallet_password_here
WALLET_LOCATION=~/.oracle/wallet
TNS_ADMIN=~/.oracle/wallet

# Connection strings
CONNECTION_STRING_HIGH=bankdb_high
CONNECTION_STRING_MEDIUM=bankdb_medium
CONNECTION_STRING_LOW=bankdb_low

# SQLcl path (for reference)
SQLCL_PATH=/opt/homebrew/Caskroom/sqlcl/26.1.0.086.1709/sqlcl/bin

# ============================================
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual passwords
# 3. Never commit .env to git!
# ============================================
